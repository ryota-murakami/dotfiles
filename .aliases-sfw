# =============================================================================
# Socket Firewall (sfw) - Package manager aliases
# =============================================================================
# Routes package manager commands through sfw for supply chain protection.
# Install: npm install -g sfw
# Docs: https://docs.socket.dev/docs/socket-firewall-free

alias npm="sfw npm"
alias npx="sfw npx"
alias pnpm="sfw pnpm"
alias pnpx="sfw pnpx"
alias yarn="sfw yarn"
alias bun="sfw bun"
