# =============================================================================
# Socket Firewall (sfw) - Package manager aliases
# =============================================================================
# Routes package manager commands through sfw for supply chain protection.
# Install: npm install -g sfw
# Docs: https://docs.socket.dev/docs/socket-firewall-free

# JavaScript/TypeScript
alias npm="sfw npm"
alias npx="sfw npx"
alias pnpm="sfw pnpm"
alias pnpx="sfw pnpx"
alias yarn="sfw yarn"
alias bun="sfw bun"

# Python
alias pip="sfw pip"
alias pip3="sfw pip3"
alias uv="sfw uv"

# Rust
alias cargo="sfw cargo"
